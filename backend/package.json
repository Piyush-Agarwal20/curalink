{
  "name": "curalink-backend",
  "version": "1.0.0",
  "description": "CuraLink Backend API with Supabase",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "setup:env": "node scripts/create-env.js",
